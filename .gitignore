**/serve.token
**/daemon.token

# local agent/session planning state
.zcode/
.omo/
.claude/settings.local.json
.aider.conf.yml
.aider.chat.history.md
.aider.input.history

# editors / os
.DS_Store
.idea/
.vscode/
*.swp
